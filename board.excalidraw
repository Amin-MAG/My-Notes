    {
      "id": "RGgfU5Vcy7xSJV-YqZWei",
      "type": "text",
      "x": 2852.5218623937485,
      "y": -1048.0167770638132,
      "width": 1056.003876637724,
      "height": 58.0648098325999,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b9U",
      "roundness": null,
      "seed": 1219017407,
      "version": 1391,
      "versionNonce": 1910737809,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772773936830,
      "link": null,
      "locked": false,
      "text": "There is no way other than calculating the results on the fly! \nThere is a way to make it better though. We can reuse large buckets as much as we can to avoid calculating a lot of points. \nLets consider calculating 35 minutes of traceroute data.",
      "fontSize": 15.483949288693308,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "There is no way other than calculating the results on the fly! \nThere is a way to make it better though. We can reuse large buckets as much as we can to avoid calculating a lot of points. \nLets consider calculating 35 minutes of traceroute data.",
      "autoResize": true,
      "lineHeight": 1.25
    },
