      "text": "if filter:OUTPUT drops → packet never leaves the machine",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "if filter:OUTPUT drops → packet never leaves the machine",
      "autoResize": true,
