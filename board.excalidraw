    },
    {
      "id": "mA2-LZ1RBotyxhfmbT6ll",
      "type": "text",
      "x": 9211.823168584937,
      "y": 480.22565159667147,
      "width": 225.0558319091797,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
