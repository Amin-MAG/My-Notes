			"type": "text",
			"x": 2852.5218623937485,
			"y": -1048.0167770638132,
			"width": 1055.73486328125,
			"height": 58.064809832599906,
			"angle": 0,
			"strokeColor": "#1e1e1e",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
