    {
      "id": "hffVGU-AGFyyM3-9Xy8pY",
      "type": "text",
      "x": 2855.288805236337,
      "y": -1844.3640457351503,
      "width": 983.6430645535332,
      "height": 38.8852461573585,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b8P",
      "roundness": null,
      "seed": 1063856735,
      "version": 1095,
      "versionNonce": 316428735,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772773936830,
      "link": null,
      "locked": false,
      "text": "The first difference is the way user asks for traceroute artifacts. \nInstead of receiving a series of points, They receive a single object representing `t` > start_at and `t` < end_at.",
      "fontSize": 15.5540984629434,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The first difference is the way user asks for traceroute artifacts. \nInstead of receiving a series of points, They receive a single object representing `t` > start_at and `t` < end_at.",
      "autoResize": true,
      "lineHeight": 1.25
    },
