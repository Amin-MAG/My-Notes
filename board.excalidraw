    {
      "id": "AfZfRB-KL0BSTv2vK7dgd",
      "type": "text",
      "x": 2871.851858639303,
      "y": -22.77678589898869,
      "width": 1034.851318359375,
      "height": 77.770492314717,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bAc",
      "roundness": null,
      "seed": 143779711,
      "version": 1648,
      "versionNonce": 501548337,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772773936830,
      "link": null,
      "locked": false,
      "text": "Here is the Design for migrating the local database to the cloud. \n\n    - For the launch, we decided to keep populating data for local database to be able to test and compare data in Cloud.\n    - All of the data such as Agent ID, Destination ID, etc is inside a JWT token in HTTP request used by services.",
      "fontSize": 15.5540984629434,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Here is the Design for migrating the local database to the cloud. \n\n    - For the launch, we decided to keep populating data for local database to be able to test and compare data in Cloud.\n    - All of the data such as Agent ID, Destination ID, etc is inside a JWT token in HTTP request used by services.",
      "autoResize": true,
      "lineHeight": 1.25
    },
