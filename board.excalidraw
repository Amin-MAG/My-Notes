      "seed": 1597481801,
      "version": 408,
      "versionNonce": 1992639497,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773612215553,
      "link": null,
      "locked": false,
      "text": "Key differences from INPUT:",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Key differences from INPUT:",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "hJDJaR8p7pD3wSegQbJ4X",
      "type": "text",
      "x": 9220.734298847725,
      "y": 532.6854741021396,
      "width": 629.354736328125,
      "height": 18.75,
      "angle": 0,
      "strokeColor": "#333",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bK4",
      "roundness": null,
      "seed": 416698921,
      "version": 530,
      "versionNonce": 1467079401,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773612215553,
      "link": null,
      "locked": false,
      "text": "raw:OUTPUT     ->  can opt out of connection tracking for locally generated packets",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "raw:OUTPUT     ->  can opt out of connection tracking for locally generated packets",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "9h3AgTkX2cv3yvO1Z2Dpd",
      "type": "text",
      "x": 9220.734298847725,
      "y": 570.2129121675139,
      "width": 690.5697021484375,
      "height": 18.75,
      "angle": 0,
      "strokeColor": "#333",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bK5",
      "roundness": null,
      "seed": 1283204361,
      "version": 576,
      "versionNonce": 1747490249,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773612215553,
      "link": null,
      "locked": false,
      "text": "nat:OUTPUT     ->  DNAT on outgoing packets (e.g. redirect localhost:80 to localhost:8080)",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "nat:OUTPUT     ->  DNAT on outgoing packets (e.g. redirect localhost:80 to localhost:8080)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "pru5TfstYtC7CS1oKTy_3",
      "type": "text",
      "x": 9220.549832775407,
      "y": 605.4559751612302,
      "width": 751.4095458984375,
      "height": 18.75,
      "angle": 0,
      "strokeColor": "#333",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bK6",
      "roundness": null,
      "seed": 1973722089,
      "version": 590,
      "versionNonce": 1812264105,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773612215553,
      "link": null,
      "locked": false,
      "text": "filter:OUTPUT  ->  firewall for outbound — rarely used but lets you block processes from calling home",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "filter:OUTPUT  ->  firewall for outbound — rarely used but lets you block processes from calling home",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Ti_AhLDt8elkvifmkaH9p",
      "type": "text",
      "x": 9220.426836917692,
      "y": 642.0807313857684,
      "width": 825.014404296875,
      "height": 18.75,
      "angle": 0,
      "strokeColor": "#333",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bK7",
      "roundness": null,
      "seed": 341522121,
      "version": 557,
      "versionNonce": 917665673,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773612215553,
      "link": null,
      "locked": false,
      "text": "POSTROUTING    ->  MASQUERADE/SNAT rewrites source IP as the packet leaves (same as FORWARD path)",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "POSTROUTING    ->  MASQUERADE/SNAT rewrites source IP as the packet leaves (same as FORWARD path)",
      "autoResize": true,
      "lineHeight": 1.25
    },
